<Window x:Class="GtavModManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:GtavModManager.Views"
        xmlns:vm="clr-namespace:GtavModManager.ViewModels"
        xmlns:conv="clr-namespace:GtavModManager.Converters"
        Title="GTA V Mod Manager"
        Width="1100" Height="700"
        MinWidth="800" MinHeight="500"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI"
        FontSize="13">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Main tab control -->
        <TabControl Grid.Row="0"
                    Style="{StaticResource TabControlStyle}"
                    SelectedIndex="{Binding SelectedTabIndex}">

            <!-- Mods tab: master-detail layout -->
            <TabItem Style="{StaticResource TabItemStyle}" Header="Mods">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="400" />
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="280" />
                    </Grid.ColumnDefinitions>

                    <views:ModListView Grid.Column="0" DataContext="{Binding ModList}" />

                    <GridSplitter Grid.Column="1" Width="5"
                                  Background="{StaticResource BorderBrush}"
                                  HorizontalAlignment="Stretch" />

                    <views:ModDetailView Grid.Column="2" DataContext="{Binding ModDetail}" />
                </Grid>
            </TabItem>

            <!-- Keybinds tab -->
            <TabItem Style="{StaticResource TabItemStyle}" Header="Keybinds">
                <views:KeybindManagerView DataContext="{Binding KeybindManager}" />
            </TabItem>

            <!-- Conflicts tab with badge -->
            <TabItem Style="{StaticResource TabItemStyle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Conflicts" VerticalAlignment="Center" />
                        <Border Background="{StaticResource ErrorBrush}"
                                CornerRadius="8" Padding="5,1" Margin="6,0,0,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ConflictBadgeCount}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding ConflictBadgeCount}" FontSize="10"
                                       Foreground="White" FontWeight="Bold" />
                        </Border>
                    </StackPanel>
                </TabItem.Header>
                <views:ConflictReportView DataContext="{Binding ConflictReport}" />
            </TabItem>

            <!-- Profiles tab -->
            <TabItem Style="{StaticResource TabItemStyle}" Header="Profiles">
                <views:ProfileManagerView DataContext="{Binding ProfileManager}" />
            </TabItem>

            <!-- Settings tab -->
            <TabItem Style="{StaticResource TabItemStyle}" Header="Settings">
                <views:SettingsView DataContext="{Binding SettingsVm}" />
            </TabItem>

        </TabControl>

        <!-- Status bar -->
        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="10,5">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" />
        </Border>
    </Grid>
</Window>

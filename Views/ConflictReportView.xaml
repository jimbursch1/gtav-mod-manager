<UserControl x:Class="GtavModManager.Views.ConflictReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GtavModManager.Converters">

    <UserControl.Resources>
        <conv:ConflictSeverityToBrushConverter x:Key="SeverityToBrush" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8">
            <Button Style="{StaticResource ButtonStyle}" Content="Rescan"
                    Command="{Binding RescanCommand}" Margin="0,0,12,0" />
            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center">
                <Run Text="Last scan: " />
                <Run Text="{Binding LastScanTime, Mode=OneWay, StringFormat='{}{0:HH:mm:ss}'}" />
            </TextBlock>
        </StackPanel>

        <!-- Conflict lists -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8">

                <!-- File conflicts -->
                <TextBlock Text="File Conflicts" FontWeight="SemiBold" FontSize="14"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6" />
                <ItemsControl ItemsSource="{Binding FileConflicts}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{Binding Severity, Converter={StaticResource SeverityToBrush}}"
                                    BorderThickness="0,0,0,2" Margin="0,0,0,6" Padding="10,8">
                                <StackPanel>
                                    <TextBlock FontFamily="Consolas" FontSize="12"
                                               Foreground="{StaticResource AccentBrush}"
                                               Text="{Binding FilePath}" />
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,2,0,0">
                                        <Run Text="Claimed by: " />
                                        <Run Text="{Binding OwnerModNames, Mode=OneWay, StringFormat='{}{0}'}" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="No file conflicts." Foreground="{StaticResource TextSecondaryBrush}" FontStyle="Italic"
                           Margin="0,0,0,12" />

                <!-- Keybind conflicts -->
                <TextBlock Text="Keybind Conflicts" FontWeight="SemiBold" FontSize="14"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,8,0,6" />
                <ItemsControl ItemsSource="{Binding KeybindConflicts}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource ErrorBrush}"
                                    BorderThickness="0,0,0,2" Margin="0,0,0,6" Padding="10,8">
                                <StackPanel>
                                    <TextBlock FontFamily="Consolas" FontWeight="SemiBold"
                                               Foreground="{StaticResource ErrorBrush}"
                                               Text="{Binding DisplayKey}" />
                                    <ItemsControl ItemsSource="{Binding Entries}" Margin="8,2,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                                                    <Run Text="{Binding ModName, Mode=OneWay}" FontWeight="SemiBold" />
                                                    <Run Text=" → " />
                                                    <Run Text="{Binding Action, Mode=OneWay}" />
                                                    <Run Text=" (" />
                                                    <Run Text="{Binding ConfigFile, Mode=OneWay}" />
                                                    <Run Text=")" />
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Dependency issues -->
                <TextBlock Text="Dependency Issues" FontWeight="SemiBold" FontSize="14"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,8,0,6" />
                <ItemsControl ItemsSource="{Binding DependencyIssues}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{Binding Severity, Converter={StaticResource SeverityToBrush}}"
                                    BorderThickness="0,0,0,2" Margin="0,0,0,6" Padding="10,8">
                                <TextBlock Foreground="{StaticResource TextPrimaryBrush}" FontSize="12">
                                    <Run Text="{Binding ModName, Mode=OneWay}" FontWeight="SemiBold" />
                                    <Run Text=" requires " />
                                    <Run Text="{Binding MissingDependency.ModName, Mode=OneWay}" Foreground="{StaticResource ErrorBrush}" />
                                    <Run Text=" which is not enabled." />
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

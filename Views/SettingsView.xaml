<UserControl x:Class="GtavModManager.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GtavModManager.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" MaxWidth="600">

            <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20" />

            <!-- GTA V Root -->
            <TextBlock Style="{StaticResource LabelStyle}" Text="GTA V Root Directory *" />
            <DockPanel Margin="0,0,0,4">
                <Button Style="{StaticResource ButtonStyle}" Content="Browse" DockPanel.Dock="Right"
                        Command="{Binding BrowseGtavRootCommand}" Margin="8,0,0,0" />
                <Button Style="{StaticResource ButtonStyle}" Content="Auto-detect" DockPanel.Dock="Right"
                        Command="{Binding AutoDetectCommand}" Margin="8,0,0,0" />
                <TextBox Style="{StaticResource TextBoxStyle}"
                         Text="{Binding GtavRootPath, UpdateSourceTrigger=PropertyChanged}" />
            </DockPanel>
            <TextBlock FontSize="11" Margin="0,0,0,16">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="✓ Valid path" />
                        <Setter Property="Foreground" Value="{StaticResource EnabledBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsGtavRootValid}" Value="False">
                                <Setter Property="Text" Value="⚠ Path not found — enter the folder containing GTA5.exe" />
                                <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Storage folder -->
            <TextBlock Style="{StaticResource LabelStyle}" Text="Mod Storage Folder (permanent home for all mod files)" />
            <DockPanel Margin="0,0,0,4">
                <Button Style="{StaticResource ButtonStyle}" Content="Browse" DockPanel.Dock="Right"
                        Command="{Binding BrowseQuarantineCommand}" Margin="8,0,0,0" />
                <TextBox Style="{StaticResource TextBoxStyle}"
                         Text="{Binding QuarantineFolder, UpdateSourceTrigger=PropertyChanged}" />
            </DockPanel>
            <TextBlock Text="Leave blank to use &lt;GTA V Root&gt;\ModManager\storage — files live here permanently; links are created in GTA V root when enabled"
                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,20" />

            <!-- Director path -->
            <TextBlock Style="{StaticResource LabelStyle}" Text="Director Agent Folder (optional)" />
            <DockPanel Margin="0,0,0,4">
                <Button Style="{StaticResource ButtonStyle}" Content="Browse" DockPanel.Dock="Right"
                        Command="{Binding BrowseDirectorCommand}" Margin="8,0,0,0" />
                <TextBox Style="{StaticResource TextBoxStyle}"
                         Text="{Binding DirectorPath, UpdateSourceTrigger=PropertyChanged}" />
            </DockPanel>
            <TextBlock Text="Folder containing director-agent.js — enables the Director launch button on the Home tab"
                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,20" />

            <!-- DIY Stream Deck path -->
            <TextBlock Style="{StaticResource LabelStyle}" Text="DIY Stream Deck Folder (optional)" />
            <DockPanel Margin="0,0,0,4">
                <Button Style="{StaticResource ButtonStyle}" Content="Browse" DockPanel.Dock="Right"
                        Command="{Binding BrowseStreamDeckCommand}" Margin="8,0,0,0" />
                <TextBox Style="{StaticResource TextBoxStyle}"
                         Text="{Binding StreamDeckPath, UpdateSourceTrigger=PropertyChanged}" />
            </DockPanel>
            <TextBlock Text="Folder containing server.js — enables the Stream Deck launch button on the Home tab"
                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,20" />

            <!-- Save -->
            <Button Style="{StaticResource AccentButtonStyle}" Content="Save Settings"
                    Command="{Binding SaveCommand}"
                    HorizontalAlignment="Left" />

            <!-- Emergency Restore -->
            <Separator Margin="0,24,0,16" />
            <TextBlock Text="Emergency Restore" FontSize="14" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6" />
            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" Margin="0,0,0,12">
                If the game won't launch or mods are missing, use this to copy all mod files
                from storage back to the GTA V directory. Safe to run at any time — files in
                storage are never deleted.
            </TextBlock>
            <Button Style="{StaticResource ButtonStyle}" Content="Restore All Mod Files"
                    Command="{Binding EmergencyRestoreCommand}"
                    HorizontalAlignment="Left" />

        </StackPanel>
    </ScrollViewer>
</UserControl>

<UserControl x:Class="GtavModManager.Views.ModDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GtavModManager.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SelectedMod}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <!-- Name / metadata -->
            <TextBlock Text="{Binding SelectedMod.Name}" FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" />
            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,12">
                <Run Text="{Binding SelectedMod.Type, Mode=OneWay}" />
                <Run Text=" · v" />
                <Run Text="{Binding SelectedMod.Version, Mode=OneWay}" />
                <Run Text=" · " />
                <Run Text="{Binding SelectedMod.Author, Mode=OneWay}" />
            </TextBlock>

            <!-- Notes -->
            <TextBlock Style="{StaticResource LabelStyle}" Text="Notes" />
            <TextBox Style="{StaticResource TextBoxStyle}"
                     Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     Height="70" Margin="0,0,0,4" />
            <Button Style="{StaticResource ButtonStyle}" Content="Save Notes"
                    Command="{Binding SaveNotesCommand}"
                    HorizontalAlignment="Left" Margin="0,0,0,12" />

            <!-- Files -->
            <TextBlock Style="{StaticResource LabelStyle}" Text="Files" />
            <ItemsControl ItemsSource="{Binding FileList}" Margin="0,0,0,12">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Dependencies -->
            <TextBlock Style="{StaticResource LabelStyle}" Text="Dependencies" />
            <ItemsControl ItemsSource="{Binding DependencyList}" Margin="0,0,0,12">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                            <Run Text="{Binding ModName, Mode=OneWay}" FontWeight="SemiBold" />
                            <Run Text=" (ID: " /><Run Text="{Binding ModId, Mode=OneWay}" /><Run Text=")" />
                        </TextBlock>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Keybinds -->
            <TextBlock Style="{StaticResource LabelStyle}" Text="Detected Keybinds" />
            <ItemsControl ItemsSource="{Binding KeybindList}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Key}" FontFamily="Consolas" FontSize="11"
                                       Foreground="{StaticResource AccentBrush}" />
                            <TextBlock Grid.Column="1" Text="{Binding Action}" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>

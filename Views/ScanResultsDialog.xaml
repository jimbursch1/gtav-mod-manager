<Window x:Class="GtavModManager.Views.ScanResultsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:GtavModManager.Converters"
        Title="Scan Results — Select Mods to Import"
        Width="780" Height="540"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Summary -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock FontSize="14" Foreground="{StaticResource TextPrimaryBrush}">
                <Run Text="Found " />
                <Run Text="{Binding Rows.Count, Mode=OneWay}" FontWeight="SemiBold" />
                <Run Text=" mods." />
                <Run Text=" " />
                <Run Text="{Binding AlreadyImportedCount, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}" />
                <Run Text=" already imported." Foreground="{StaticResource TextSecondaryBrush}" />
            </TextBlock>
        </StackPanel>

        <!-- Detected frameworks -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding DetectedFrameworks}" Margin="0,0,0,10">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="3" Margin="0,0,8,4" Padding="6,3">
                        <TextBlock VerticalAlignment="Center">
                            <Run Text="✓ " Foreground="{StaticResource EnabledBrush}" />
                            <Run Text="{Binding Framework.DisplayName, Mode=OneWay}"
                                 Foreground="{StaticResource TextPrimaryBrush}" FontSize="11" />
                        </TextBlock>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Filter + select all/none -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBox Style="{StaticResource TextBoxStyle}" Width="220"
                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,10,0" />
            <Button Style="{StaticResource ButtonStyle}" Content="Select All"
                    Command="{Binding SelectAllCommand}" Margin="0,0,6,0" />
            <Button Style="{StaticResource ButtonStyle}" Content="Select None"
                    Command="{Binding SelectNoneCommand}" Margin="0,0,0,0" />
        </StackPanel>

        <!-- Results grid -->
        <DataGrid Grid.Row="3"
                  Style="{StaticResource DataGridStyle}"
                  ItemsSource="{Binding FilteredRows}"
                  IsReadOnly="False"
                  Margin="0,0,0,10">
            <DataGrid.Columns>

                <!-- Checkbox -->
                <DataGridTemplateColumn Header="" Width="36" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding Selected, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding AlreadyImported, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Editable name -->
                <DataGridTemplateColumn Header="Name" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name, Mode=OneWay}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" Margin="4,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TextBoxStyle}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Type -->
                <DataGridTextColumn Header="Type" Binding="{Binding Type, Mode=OneWay}" Width="130" IsReadOnly="True" />

                <!-- File count -->
                <DataGridTextColumn Header="Files" Binding="{Binding FileCount, Mode=OneWay}" Width="50" IsReadOnly="True" />

                <!-- Already imported indicator -->
                <DataGridTemplateColumn Header="" Width="90" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="already added"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontStyle="Italic" FontSize="11"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding AlreadyImported, Converter={StaticResource BoolToVis}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <DockPanel Grid.Row="4">
            <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}">
                <Run Text="{Binding SelectedCount, Mode=OneWay}" FontWeight="SemiBold"
                     Foreground="{StaticResource TextPrimaryBrush}" />
                <Run Text=" mods selected for import" />
            </TextBlock>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource ButtonStyle}" Content="Cancel"
                        IsCancel="True" Margin="0,0,8,0" />
                <Button Style="{StaticResource AccentButtonStyle}" Content="Import Selected"
                        IsDefault="True" Click="ImportSelected_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>

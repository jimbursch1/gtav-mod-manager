<UserControl x:Class="GtavModManager.Views.ProfileManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GtavModManager.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8">
            <Button Style="{StaticResource AccentButtonStyle}" Content="+ Create Profile"
                    Command="{Binding CreateProfileCommand}" Margin="0,0,8,0" />
        </StackPanel>

        <!-- Profile list -->
        <DataGrid Grid.Row="1"
                  Style="{StaticResource DataGridStyle}"
                  ItemsSource="{Binding Profiles}"
                  SelectedItem="{Binding SelectedProfile}"
                  Margin="8,4,8,4">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="Last Activated" Binding="{Binding LastActivated, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="160" />
                <DataGridTemplateColumn Header="" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource AccentButtonStyle}" Content="Switch"
                                        Command="{Binding DataContext.SwitchProfileCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Padding="8,2" Margin="2" />
                                <Button Style="{StaticResource ButtonStyle}" Content="✕"
                                        Command="{Binding DataContext.DeleteProfileCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Padding="6,2" Margin="2" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Operation status -->
        <StackPanel Grid.Row="2" Margin="8,4">
            <TextBlock Text="Switching profile..." Foreground="{StaticResource AccentBrush}"
                       Visibility="{Binding IsSwitching, Converter={StaticResource BoolToVis}}" />
            <TextBlock Text="{Binding OperationError}" Foreground="{StaticResource ErrorBrush}"
                       TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding OperationError}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding OperationError}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>
    </Grid>
</UserControl>

<UserControl x:Class="GtavModManager.Views.GameVersionSnapshotView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GtavModManager.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Description -->
        <TextBlock Grid.Row="0"
                   Margin="8,8,8,4"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Text="Save copies of GTA5.exe, update.rpf, and ScriptHookV.dll before a Rockstar update. Restore them afterward to roll back to a working state." />

        <!-- Toolbar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="8,4,8,4">
            <Button Style="{StaticResource AccentButtonStyle}" Content="+ Save Snapshot"
                    Command="{Binding CreateSnapshotCommand}" Margin="0,0,8,0" />
        </StackPanel>

        <!-- Snapshot list -->
        <DataGrid Grid.Row="2"
                  Style="{StaticResource DataGridStyle}"
                  ItemsSource="{Binding Snapshots}"
                  SelectedItem="{Binding SelectedSnapshot}"
                  Margin="8,4,8,4">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="*" MinWidth="140" />
                <DataGridTextColumn Header="Game Version" Binding="{Binding GameVersion}" Width="120" />
                <DataGridTextColumn Header="Date" Binding="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="140" />
                <DataGridTextColumn Header="Size" Binding="{Binding TotalSizeDisplay}" Width="80" />
                <DataGridTemplateColumn Header="" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource AccentButtonStyle}" Content="Restore"
                                        Command="{Binding DataContext.RestoreSnapshotCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Padding="8,2" Margin="2" />
                                <Button Style="{StaticResource ButtonStyle}" Content="✕"
                                        Command="{Binding DataContext.DeleteSnapshotCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Padding="6,2" Margin="2" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status -->
        <StackPanel Grid.Row="3" Margin="8,4">
            <TextBlock Text="Working..." Foreground="{StaticResource AccentBrush}"
                       Visibility="{Binding IsWorking, Converter={StaticResource BoolToVis}}" />
            <TextBlock Text="{Binding OperationError}" Foreground="{StaticResource ErrorBrush}"
                       TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding OperationError}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding OperationError}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>
    </Grid>
</UserControl>
